# GitHub API
GITHUB_TOKEN=your_github_personal_access_token_here

# LLM Configuration - uses local Claude HTTP endpoint (via litellm proxy at http://localhost:4000)
LLM_MODEL=claude-3-5-sonnet
LLM_TEMPERATURE=0.2
CLAUDE_API_BASE=http://localhost:4000
CLAUDE_API_KEY=sk-local-dev-key

# Circuit breaker tuning for Claude
CLAUDE_FAILURE_THRESHOLD=3
CLAUDE_FAILURE_RECOVERY_SECONDS=60

# Ollama fallback configuration (used when Claude fails or is unavailable)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=deepseek-v4-flash:cloud
OLLAMA_TEMPERATURE=0.2

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SECONDS=600

# Optional: Docker environment
COMPOSE_PROJECT_NAME=github-analyzer
